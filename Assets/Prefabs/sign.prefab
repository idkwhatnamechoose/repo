  - {fileID: -555538041781316410, guid: 55c942ec92597264985fb3ca5fba8370, type: 3}
  - {fileID: 21300000, guid: 9c08f8de9e4404a44acc378f7c0e358e, type: 3}
  - {fileID: 21300000, guid: cc9f8cc7b88d9dd43bb8665ecec447a2, type: 3}
  context:
  - 
  - "\u041F\u0440\u0438\u0432\u0435\u0442! \u042D\u0442\u043E \u0442\u0435\u0441\u0442
    \u043D\u043E\u0432\u043E\u0433\u043E \u0438\u043D\u0442\u0435\u0440\u0444\u0435\u0439\u0441\u0430
    \u0440\u0430\u0437\u0433\u043E\u0432\u043E\u0440\u0430"
  - "\u0412\u043E\u0442 \u0442\u0430\u043A\u0430\u044F \u0445\u0440\u0435\u043D\u044C
    \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u0430\u0441\u044C"
  - "\u041F\u0435\u0440\u0432\u0430\u044F \u043D\u043E\u0432\u0430\u044F \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0430
    - \u043F\u0440\u0438\u0441\u044F\u0434"
  - "\u0414\u043B\u044F \u044D\u0442\u043E\u0433\u043E \u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E
    \u043D\u0430\u0436\u0430\u0442\u044C \u043A\u043D\u043E\u043F\u043A\u0443 LEFTSHIFT(\u0434\u043B\u044F
    \u041F\u041A) \u0438\u043B\u0438 \u043A\u043D\u043E\u043F\u043A\u0443 \u0441
    \u043A\u0443\u0431\u0431\u0438 \u0438 \u0441\u043E \u0441\u0442\u0440\u0435\u043B\u043A\u043E\u0439
    \u0432\u043D\u0438\u0437(\u0434\u043B\u044F \u0442\u0435\u043B\u0435\u0444\u043E\u043D\u043E\u0432)"
  EnglishContext:
  - 
  - "\u041F\u0440\u0438\u0432\u0435\u0442! \u042D\u0442\u043E \u0442\u0435\u0441\u0442
    \u043D\u043E\u0432\u043E\u0433\u043E \u0438\u043D\u0442\u0435\u0440\u0444\u0435\u0439\u0441\u0430
    \u0440\u0430\u0437\u0433\u043E\u0432\u043E\u0440\u0430"
  - "\u0412\u043E\u0442 \u0442\u0430\u043A\u0430\u044F \u0445\u0440\u0435\u043D\u044C
    \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u0430\u0441\u044C"
  SpanishContext:
  - 
  - "\u041F\u0440\u0438\u0432\u0435\u0442! \u042D\u0442\u043E \u0442\u0435\u0441\u0442
    \u043D\u043E\u0432\u043E\u0433\u043E \u0438\u043D\u0442\u0435\u0440\u0444\u0435\u0439\u0441\u0430
    \u0440\u0430\u0437\u0433\u043E\u0432\u043E\u0440\u0430"
  - "\u0412\u043E\u0442 \u0442\u0430\u043A\u0430\u044F \u0445\u0440\u0435\u043D\u044C
    \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u0430\u0441\u044C"
  textCollection: 2
  txt: {fileID: 6263245421484935186}
  letterDelay: 0.1
  pl: {fileID: 0}

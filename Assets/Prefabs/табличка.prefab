  emotions:
  - {fileID: 0}
  context:
  - 
  - "\u041F\u0440\u0438\u0432\u0435\u0442!"
  - "\u042D\u0442\u043E \u0434\u0435\u043C\u043E \u0441\u043E\u0437\u0434\u0430\u043D\u043E,
    \u0447\u0442\u043E\u0431\u044B \u043F\u043E\u043A\u0430\u0437\u0430\u0442\u044C
    \u043D\u043E\u0432\u044B\u0435 \u0438\u0433\u0440\u043E\u0432\u044B\u0435 \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0438,
    \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0431\u0443\u0434\u0443\u0442 \u0432
    \u0438\u0433\u0440\u0435"
  - "\u041F\u0435\u0440\u0432\u0430\u044F \u043D\u043E\u0432\u0430\u044F \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0430
    - \u043F\u0440\u0438\u0441\u044F\u0434"
  - "\u0414\u043B\u044F \u044D\u0442\u043E\u0433\u043E \u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E
    \u043D\u0430\u0436\u0430\u0442\u044C \u043A\u043D\u043E\u043F\u043A\u0443 LEFTSHIFT(\u0434\u043B\u044F
    \u041F\u041A) \u0438\u043B\u0438 \u043A\u043D\u043E\u043F\u043A\u0443 \u0441
    \u043A\u0443\u0431\u0431\u0438 \u0438 \u0441\u043E \u0441\u0442\u0440\u0435\u043B\u043A\u043E\u0439
    \u0432\u043D\u0438\u0437(\u0434\u043B\u044F \u0442\u0435\u043B\u0435\u0444\u043E\u043D\u043E\u0432)"

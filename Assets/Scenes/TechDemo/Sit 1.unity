  - 
  - "\u041C\u043E\u043B\u043E\u0434\u0435\u0446!"
  - "\u0422\u0435\u043F\u0435\u0440\u044C \u043F\u0435\u0440\u0435\u0439\u0434\u0451\u043C
    \u043A \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0435\u0439 \u043C\u0435\u0445\u0430\u043D\u0438\u043A\u0435"
  - "\u0423\u0434\u0430\u0440\u044B"
  - "\u0420\u0430\u043D\u044C\u0448\u0435 \u043A\u0443\u0431\u0431\u0438 \u043F\u0440\u044B\u0433\u0430\u043B
    \u043D\u0430 \u0433\u043E\u043B\u043E\u0432\u0443 \u0444\u0435\u0439\u043A \u043A\u0443\u0431\u0431\u0438,
    \u0447\u0442\u043E\u0431\u044B \u0442\u043E\u0433\u043E \u0443\u0431\u0438\u0442\u044C"
  - "\u0422\u0435\u043F\u0435\u0440\u044C \u0432\u043C\u0435\u0441\u0442\u043E \u044D\u0442\u043E\u0433\u043E
    \u043C\u044B \u043D\u0430\u0443\u0447\u0438\u043B\u0438 \u043A\u0443\u0431\u0431\u0438..."
  - "\u0441\u0440\u0430\u0436\u0430\u0442\u044C\u0441\u044F!"
  - "\u041D\u0430\u0436\u0438\u043C\u0430\u0435\u0448\u044C \u043D\u0430 \u043A\u043D\u043E\u043F\u043A\u0443
    \u0438 \u0432\u0443\u0430\u043B\u044F!"
  - "\u041A\u0443\u0431\u0431\u0438 \u0438\u0441\u043F\u043E\u043B\u043D\u044F\u0435\u0442
    \u043A\u0430\u0440\u0430\u0442\u044D"

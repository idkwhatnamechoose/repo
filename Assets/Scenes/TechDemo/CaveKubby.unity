    \u043D\u0435 \u043F\u043E\u0437\u0432\u043E\u043B\u0435\u043D\u043E"
  - "\u041E\u043D \u0441\u0436\u0438\u043C\u0430\u0435\u0442 \u043A\u0443\u0431\u0431\u0438"
  - "\u0418 \u0443\u0431\u0438\u0432\u0430\u0435\u0442 \u0435\u0433\u043E"
  - "\u041A\u0441\u0442\u0430\u0442\u0438..."

  - {fileID: 21300000, guid: 64c411466aeb26a4ba012440a65ede20, type: 3}
  context:
  - 
  - "\u041E\u0442\u043B\u0438\u0447\u043D\u043E!"
  - "\u0422\u044B \u043F\u0440\u043E\u0448\u0451\u043B \u044D\u0442\u043E\u0442 \u0443\u0440\u043E\u0432\u0435\u043D\u044C!!!"
  - "\u041F\u043E\u0434\u043E\u0439\u0434\u0438 \u043A\u043E \u043C\u043D\u0435 \u0447\u0442\u043E
    \u0431\u044B \u0437\u0430\u0432\u0435\u0440\u0448\u0438\u0442\u044C \u0435\u0433\u043E!!!"
  - "\u0438\u0431\u043E..."
  - "\u0411\u0443\u0434\u0435\u0442 \u0431\u043E\u043B\u044C\u043D\u043E"
  - "\u041E\u043D\u0438 \u043E\u0442\u0440\u0430\u0436\u0430\u044E\u0442 \u0443\u0434\u0430\u0440\u044B
    \u0441 \u043D\u0435\u0431\u0430..."
  - "\u0442\u0430\u043A \u0447\u0442\u043E \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u0443\u0439
    \u043A\u0443\u043B\u0430\u043A\u0438!"
  EnglishContext:
  - 
  - Great!
  - You have passed this level!!!
  - Come to me to finish it!!!
  SpanishContext:
  - 
  - "\xA1Excelente!"
  - "\xA1\xA1\xA1Has pasado este nivel!!!"
  - "\xA1\xA1\xA1Venid a mi para terminarlo!!!"
  textCollection: 3
  txt: {fileID: 1312565335}
  letterDelay: 0.1

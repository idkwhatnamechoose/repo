  - {fileID: 21300000, guid: 223b18e1f511edf4bbadae845359c7b2, type: 3}
  - {fileID: 21300000, guid: a81633e2f2c7b204a9d160b8d1f0a7b2, type: 3}
  - {fileID: 21300000, guid: a81633e2f2c7b204a9d160b8d1f0a7b2, type: 3}
  context:
  - 
  - "\u041F\u0440\u0438\u0432\u0435\u0442 \u043E\u043F\u044F\u0442\u044C!!!"
  - "\u042F \u0442\u0443\u0442 \u0432\u043D\u0438\u0437\u0443"
  - "\u0410 \u0442\u0430\u043C \u0434\u0430\u043B\u044C\u0448\u0435..."
  - "\u0422\u0443\u043F\u044B\u0435 \u0444\u0435\u0439\u043A\u0438"
  - "\u041D\u043E \u043D\u0435 \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E
    \u0442\u0443\u043F\u044B\u0435 \u043A\u0430\u043A \u0440\u0430\u043D\u044C\u0448\u0435!!!"
  - "\u0422\u0435\u043F\u0435\u0440\u044C \u043E\u043D\u0438 \u0445\u043E\u0442\u044F\u0442
    \u0438 \u0434\u0435\u0440\u0443\u0442\u0441\u044F!"
  EnglishContext:
  - 
  - Hello again!
  - I'm down here
  - And then further...
  - Stupid fakes
  - But not as stupid as before!!!
  - Now they want and fight!
  SpanishContext:
  - 
  - Hola de nuevo!!!
  - "Estoy aqu\xED abajo"
  - "Y luego m\xE1s..."
  - "Falsificaciones est\xFApidas"
  - "\xA1\xA1\xA1Pero no tan tonto como antes!!!"
  - "\xA1Ahora quieren y pelean!"

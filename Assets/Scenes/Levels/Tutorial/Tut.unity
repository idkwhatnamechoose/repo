    - target: {fileID: 5224126692169252128, guid: 316b3a2f2c716e74facd23d305bda5a4, type: 3}
      propertyPath: emotions.Array.size
      value: 12
      objectReference: {fileID: 0}
    - target: {fileID: 5224126692169252128, guid: 316b3a2f2c716e74facd23d305bda5a4, type: 3}
      propertyPath: 'context.Array.data[1]'
      value: "\u0418 \u0442\u0430\u043A, \u043D\u043E\u0432\u043E\u0431\u0440\u0430\u043D\u0435\u0446,
        \u043C\u044B \u0437\u0430\u043C\u0435\u0442\u0438\u043B\u0438 \u0442\u0432\u043E\u0438
        \u0431\u043E\u0435\u0432\u044B\u0435 \u0441\u043F\u043E\u0441\u043E\u0431\u043D\u043E\u0441\u0442\u0438,
        \u0430 \u0437\u043D\u0430\u0447\u0438\u0442, \u0442\u044B \u0434\u043E\u043B\u0436\u0435\u043D
        \u043F\u0440\u0438\u0441\u043E\u0435\u0434\u0438\u043D\u0438\u0442\u044C\u0441\u044F
        \u043A \u043D\u0430\u0448\u0438\u043C \u0440\u044F\u0434\u0430\u043C, \u0447\u0442\u043E\u0431\u044B
        \u0437\u0430\u0449\u0438\u0449\u0430\u0442\u044C \u0441\u0432\u043E\u044E
        \u0440\u043E\u0434\u0438\u043D\u0443."
      objectReference: {fileID: 0}
    - target: {fileID: 5224126692169252128, guid: 316b3a2f2c716e74facd23d305bda5a4, type: 3}
      propertyPath: 'context.Array.data[2]'
      value: "(\u042D\u043C\u043C.. \u0447\u0435\u0433\u043E?)"
      objectReference: {fileID: 0}
    - target: {fileID: 5224126692169252128, guid: 316b3a2f2c716e74facd23d305bda5a4, type: 3}
      propertyPath: 'context.Array.data[3]'
      value: "\u042D\u044D\u044D.. \u0445\u043E\u0440\u043E\u0448\u043E"
      objectReference: {fileID: 0}
    - target: {fileID: 5224126692169252128, guid: 316b3a2f2c716e74facd23d305bda5a4, type: 3}
      propertyPath: 'context.Array.data[4]'
      value: "\u0417\u043D\u0430\u0447\u0438\u0442, \u0431\u0443\u0434\u0435\u043C
        \u0438\u0434\u0442\u0438 \u043F\u043E \u0441\u043F\u0438\u0441\u043A\u0443
        \u043D\u0430\u0432\u044B\u043A\u043E\u0432. \u0422\u0430\u043A \u0447\u0442\u043E
        \u0434\u0430\u0432\u0430\u0439 \u043D\u0430\u0447\u043D\u0451\u043C \u043E\u0442\u0442\u0430\u0447\u0438\u0432\u0430\u0442\u044C
        \u0438\u0445, \u043D\u0430\u0447\u0438\u043D\u0430\u044F \u0441 \u0441\u0430\u043C\u044B\u0445
        \u0430\u0437\u043E\u0432."
      objectReference: {fileID: 0}
    - target: {fileID: 5224126692169252128, guid: 316b3a2f2c716e74facd23d305bda5a4, type: 3}
      propertyPath: 'context.Array.data[5]'
      value: "\u0435\u0440\u0432\u044B\u043C \u0434\u0435\u043B\u043E\u043C \u0431\u043E\u0435\u0446
        \u0434\u043E\u043B\u0436\u0435\u043D \u043D\u0430\u0443\u0447\u0438\u0442\u044C\u0441\u044F
        \u043F\u0435\u0440\u0435\u043F\u0440\u044B\u0433\u0438\u0432\u0430\u0442\u044C
        \u043F\u0440\u043E\u043F\u0430\u0441\u0442\u0438, \u043A\u043E\u0442\u043E\u0440\u044B\u0435
        \u043C\u044B \u0432\u044B\u0440\u044B\u043B\u0438 \u0434\u043B\u044F \u0442\u0440\u0435\u043D\u0438\u0440\u043E\u0432\u043E\u043A.
        \u0412\u0435\u0434\u044C \u0437\u0430 \u043F\u0440\u0435\u0434\u0435\u043B\u0430\u043C\u0438
        \u0431\u0435\u0437\u043E\u043F\u0430\u0441\u043D\u043E\u0439 \u0437\u043E\u043D\u044B
        \u043F\u043E\u0434\u043E\u0431\u043D\u044B\u0435 \u044F\u043C\u044B, \u043D\u043E
        \u0443\u0436\u0435 \u0441 \u043D\u0435\u0438\u0437\u0432\u0435\u0441\u0442\u043D\u043E\u0439
        \u0433\u043B\u0443\u0431\u0438\u043D\u043E\u0439."
      objectReference: {fileID: 0}
    - target: {fileID: 5224126692169252128, guid: 316b3a2f2c716e74facd23d305bda5a4, type: 3}
      propertyPath: 'context.Array.data[6]'
      value: "\u041D\u0430\u0436\u043C\u0438 SPACE \u0438\u043B\u0438 \u0441\u0442\u0440\u0435\u043B\u043A\u0443
